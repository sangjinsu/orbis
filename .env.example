ORBIS_ADDR=:8080
ORBIS_DATA_DIR=data
ORBIS_LLM_PROVIDER=openai
ORBIS_LLM_MODEL=replace-me
ORBIS_RUN_TIMEOUT=2m
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com

# Tool calling (v0.2). Defaults are safe: only the "safe" toolset is enabled and
# dangerous tools are denied. Override only when you understand the risk.
ORBIS_TOOLSETS=safe
ORBIS_TOOL_TIMEOUT_DEFAULT=5s
ORBIS_TOOL_TIMEOUT_MAX=30s
ORBIS_TOOL_RETRY_MAX_ATTEMPTS=2
ORBIS_TOOL_RETRY_INITIAL_DELAY=500ms
ORBIS_TOOL_RETRY_MAX_DELAY=5s
ORBIS_TOOL_RETRY_BACKOFF=2.0

# Tool-denial continuation (v1.5). How many times a run may continue after a tool
# is rejected by policy, by feeding the denial back to the LLM to replan. 0 fails
# the run on the first rejection (v0.2 behavior).
ORBIS_TOOL_DENIAL_CONTINUATION_MAX=2

# WebSocket read timeout. 0 (default) disables it so idle subscriber connections
# stay open between events. Set a duration (e.g. 120s) only if you want to drop
# idle client connections.
ORBIS_WS_READ_TIMEOUT=0s

# Skills (v1). Procedural knowledge loaded into the LLM context before planning.
# Enabled by default; set ORBIS_SKILLS_ENABLED=false to run without skills.
ORBIS_SKILLS_ENABLED=true
ORBIS_SKILLS_DIR=data/skills
ORBIS_SKILLS_MAX_SELECTED=3
ORBIS_SKILLS_MAX_CHARS=12000

# Skill learning (v2 + v2.1). The runtime creates reviewable proposals from runs;
# promotion is never automatic. Named tokens use name:role:token entries.
# reviewer may create/edit/approve/reject proposals; admin also may reload skills.
# If both auth settings are empty, mutations are disabled while reads stay open.
ORBIS_SKILL_LEARNING_ENABLED=true
ORBIS_SKILL_PROPOSALS_DIR=data/skill_proposals
ORBIS_SKILL_AUDIT_PATH=data/audit/skill_audit.jsonl
ORBIS_AUTH_TOKENS=alice:admin:replace-admin-token,bob:reviewer:replace-reviewer-token
# Optional legacy compatibility key. Leave empty when using ORBIS_AUTH_TOKENS.
ORBIS_ADMIN_TOKEN=
ORBIS_SKILL_AUTO_PROPOSE=false
