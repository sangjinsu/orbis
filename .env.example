ORBIS_ADDR=:8080
ORBIS_DATA_DIR=data
ORBIS_LLM_PROVIDER=openai
ORBIS_LLM_MODEL=replace-me
ORBIS_RUN_TIMEOUT=2m
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com

# Tool calling (v0.2). Defaults are safe: only the "safe" toolset is enabled and
# dangerous tools are denied. Override only when you understand the risk.
ORBIS_TOOLSETS=safe
ORBIS_TOOL_TIMEOUT_DEFAULT=5s
ORBIS_TOOL_TIMEOUT_MAX=30s
ORBIS_TOOL_RETRY_MAX_ATTEMPTS=2
ORBIS_TOOL_RETRY_INITIAL_DELAY=500ms
ORBIS_TOOL_RETRY_MAX_DELAY=5s
ORBIS_TOOL_RETRY_BACKOFF=2.0
